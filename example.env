# AssayManager config — copy this file to ".env" and fill in your values.
# ".env" is gitignored; this template is committed. Real OS environment
# variables override anything set here.

# NCBI contact email — required to enable BLAST reference fetching.
AM_NCBI_EMAIL=you@example.org

# NCBI tool name sent with requests (optional; defaults to "AssayManager").
#AM_NCBI_TOOL=AssayManager

# NCBI API key — optional; raises the request rate limit. Keep this secret.
#AM_NCBI_API_KEY=

# Max concurrent analysis runs (default 1). A run holds a slot for its whole
# duration, so with BLAST runs this also bounds how many NCBI queries happen at
# once — keep at 1 for public NCBI; raise only with your own BLAST DB.
#AM_MAX_CONCURRENT_RUNS=1

# Other server settings may also go here, e.g.:
#AM_ADDR=:8080
#AM_DB=assaymanager.db
#AM_INCLUSIVITY_BIN=./assets/inclusivity_check_blast
